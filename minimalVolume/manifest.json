{
  "manifest_version": 3,
  "name": "Minimal Volume Booster",
  "description": "Extensión para aumentar el volumen de la pestaña actual.",
  "version": "1.0.0",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_title": "Minimal Volume Booster",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "options_page": "options.html",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}